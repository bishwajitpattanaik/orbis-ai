[40.061195, "o", "\u001b[95m  \u256d \u001b[95m\u2b21 Orbis AI\u001b[39m\u001b[95m \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256e\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[35m\u001b[4m\u001b[1m# Step: Obtain ESTA or Visa\u001b[22m\u001b[24m\u001b[39m                                                                                                                          \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0m\u001b[1m1. Determine your eligibility\u001b[22m\u001b[0m                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mCheck if your country is a **Visa Waiver Program (VWP)** participant:                                                                              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   https://travel.state.gov/content/travel/en/us-visas/tourism-visit/visa-waiver-program.html\u001b[0m                                                           \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mIf your country is on the list **and** you meet the VWP criteria (passport from a VWP country, traveling for tourism/business < 90 days, etc.),    \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   you can use **ESTA** instead of a visa.\u001b[0m                                                                                                              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0m\u001b[1m2. If eligible for VWP \u2192 Apply for ESTA\u001b[22m\u001b[0m                                                                                                              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mApply online only at the official site: **https://esta.cbp.dhs.gov/**\u001b[0m                                                                              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0m**Fee:** $40.27 (paid by credit/debit card on the official site)\u001b[0m                                                                                   \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0m**Processing:** allow up to **72 hours**, though many are approved within minutes \u2014 apply well before travel.\u001b[0m                                      \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mYou'll need: valid e-passport, travel itinerary details, and the application info.\u001b[0m                                                                 \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0m\u26a0\ufe0f Only use the official `.gov` site to avoid third-party scams charging extra fees.\u001b[0m                                                               \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0m\u001b[1m3. If NOT eligible for VWP \u2192 Apply for a US tourist visa (B-2)\u001b[22m\u001b[0m                                                                                       \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m        "]
[40.06200100000001, "o", "                                                                                                                                                \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mComplete the **DS-160** form online: https://ceac.state.gov/CEAC/\u001b[0m                                                                                  \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mPay the visa application fee (varies by country; confirm on the embassy site).\u001b[0m                                                                     \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mSchedule an interview at the nearest **US embassy or consulate**.\u001b[0m                                                                                  \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mAttend the interview with your passport, photo, DS-160 confirmation, and supporting documents (proof of ties, finances, itinerary).\u001b[0m                \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0m\u001b[1mNote:\u001b[22m I've given you the official links and the verified ESTA fee ($40.27) from the instruction. For the visa fee and                                \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   exact embassy interview wait times, those depend on your nationality \u2014 a quick web search for your specific country's US                             \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   embassy page would confirm the current figures.\u001b[0m                                                                                                      \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n\u001b[95m  \u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256f\u001b[39m\r\n\r\n"]
[40.262001000000005, "o", "\u001b[31m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\n\r\n\u001b[48;5;214m\u001b[97m\u001b[1m STEP 3/10 \u001b[22m\u001b[39m\u001b[49m \u001b[38;5;214m\u001b[1mVerify passport validity\u001b[22m\u001b[39m\r\n\r\n\u001b[38;5;214m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\n"]
