[6.109024000000001, "o", "\r\n\r\n"]
[6.111970000000002, "o", "\u001b[92m  \u2554\u2550\u2550\u2550\u2550\u2550 \u001b[33m\u2b21 Orbis CLI\u001b[39m\u001b[92m \u2550\u2550\u2550\u2550\u2550\u2557\u001b[39m\r\n  \u001b[92m\u2551\u001b[39m                       \u001b[92m\u2551\u001b[39m\r\n  \u001b[92m\u2551\u001b[39m   \u001b[93m\u001b[1m  \ud83e\udded  Plan Mode  \u001b[22m\u001b[39m   \u001b[92m\u2551\u001b[39m\r\n  \u001b[92m\u2551\u001b[39m                       \u001b[92m\u2551\u001b[39m\r\n\u001b[92m  \u255a\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u255d\u001b[39m\r\n"]
[6.311970000000002, "o", "\u001b[?25l\u001b[90m\u2502\u001b[39m\r\n\u001b[36m\u25c6\u001b[39m  \u001b[93mContinue a previous session or start new?\u001b[39m\r\n\u001b[36m\u2502\u001b[39m  \u001b[32m\u25cf\u001b[39m \u001b[92m\uff0b  New Session\u001b[39m\r\n\u001b[36m\u2502\u001b[39m  \u001b[2m\u25cb\u001b[22m \u001b[2m\u001b[96mGive me a plan to automate my daily tasks using ai\u001b[39m\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[2m\u25cb\u001b[22m \u001b[2m\u001b[96mCreate an url shortener for me\u001b[39m\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[2m\u25cb\u001b[22m \u001b[2m\u001b[96mGive me a weekly diet plan for two months\u001b[39m\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[2m\u25cb\u001b[22m \u001b[2m\u001b[96mNew plan conversation\u001b[39m\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[2m\u25cb\u001b[22m \u001b[2m\u001b[96mGive me a plan for vacation to Italy for 4 weeks\u001b[39m\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[2m\u25cb\u001b[22m \u001b[2m\u001b[96mTell me about Google's Alphabet\u001b[39m\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[2m\u25cb\u001b[22m \u001b[2m\u001b[96mTell me about Google's Deepmind\u001b[39m\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[2m\u25cb\u001b[22m \u001b[2m\u001b[96mCreate a leetcode problem finder web app for me\u001b[39m\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[2m\u25cb\u001b[22m \u001b[2m\u001b[91m\ud83d\uddd1  Manage / delete sessions\u001b[39m\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[2m\u2191/\u2193\u001b[22m to navigate \u2022 \u001b[2mEnter:\u001b[22m confirm\r\n\u001b[36m\u2514\u001b[39m\r\n"]
