1b[95m\u2502\u001b[39m   \u001b[90m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\u001b[90m\u2534\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\u001b[39m\u001b[0m                                                                                                                            \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0m\u001b[1mTravel logistics between legs:\u001b[22m\u001b[0m                                                                                                                       \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mNYC \u2192 D.C.: Amtrak Northeast Regional (~3.5 hrs) or short flight\u001b[0m                                                                                   \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mD.C. \u2192 Chicago: Flight (~2 hrs)\u001b[0m                                                                                                                    \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mChicago \u2192 Las Vegas: Flight (~4 hrs)\u001b[0m                                                                                                               \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mLas Vegas \u2192 Los Angeles: Flight (~1 hr) or scenic drive (~4.5 hrs)\u001b[0m                                                                                 \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0m\u001b[1mNotes:\u001b[22m\u001b[0m                                                                                                                                               \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mFly into NYC (JFK/EWR) and depart from LAX to avoid backtracking.\u001b[0m                                                                                  \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mBook Grand Canyon excursions in advance; weather affects availability.\u001b[0m                                                                             \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mThis is a fast-paced trip \u2014 cut a city if you prefer slower travel.\u001b[0m                                                                                \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502"]
[62.716913999999996, "o", "\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0mWant me to add estimated costs, best seasons to visit, or swap in national parks (e.g., Yellowstone, Zion)?\u001b[0m                                          \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n\u001b[95m  \u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256f\u001b[39m\r\n\r\n"]
