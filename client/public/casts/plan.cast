[121.87817999999996, "o", "\r\n\u001b[33m   \u256d\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 \ud83c\udf0a Goodbye \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256e\u001b[39m\r\n   \u001b[33m\u2502\u001b[39m                                                 \u001b[33m\u2502\u001b[39m\r\n   \u001b[33m\u2502\u001b[39m   \u001b[93m\u2728 Thanks for using Orbis. See you soon! \u2728\u001b[39m   \u001b[33m\u2502\u001b[39m\r\n   \u001b[33m\u2502\u001b[39m                                                 \u001b[33m\u2502\u001b[39m\r\n\u001b[33m   \u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256f\u001b[39m\r\n\r\n"]
