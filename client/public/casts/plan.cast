[6.711970000000002, "o", "\r\n\u001b[33m\u256d\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 Plan Session \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256e\u001b[39m\r\n\u001b[33m\u2502\u001b[39m                                        \u001b[33m\u2502\u001b[39m\r\n\u001b[33m\u2502\u001b[39m   \u001b[96mSession\u001b[39m:  \u001b[37m\u001b[1mNew plan conversation\u001b[22m\u001b[39m      \u001b[33m\u2502\u001b[39m\r\n\u001b[33m\u2502\u001b[39m   \u001b[96mID:\u001b[39m      \u001b[37m\u001b[1mcmrqhoup30001d2qxznru171d\u001b[22m\u001b[39m   \u001b[33m\u2502\u001b[39m\r\n\u001b[33m\u2502\u001b[39m   \u001b[96mMode:\u001b[39m    \u001b[37m\u001b[1mplan\u001b[22m\u001b[39m                        \u001b[33m\u2502\u001b[39m\r\n\u001b[33m\u2502\u001b[39m                                        \u001b[33m\u2502\u001b[39m\r\n\u001b[33m\u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256f\u001b[39m\r\n\r\n"]
