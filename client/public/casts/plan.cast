[110.71560399999996, "o", "\u001b[1G\u001b[J\u001b[32m\u25c7\u001b[39m  \r\n\u001b[?25h"]
[110.71612499999995, "o", "\r\n\u001b[32m\u2714\u001b[39m \u001b[92m\u001b[1mPrepare border documents\u001b[22m\u001b[39m\r\n\r\n"]
[110.73542899999995, "o", "\u001b[95m  \u256d \u001b[95m\u2b21 Orbis AI\u001b[39m\u001b[95m \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256e\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[35m\u001b[4m\u001b[1m# Step: Prepare Border Documents\u001b[22m\u001b[24m\u001b[39m                                                                                                                     \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0mThis step focuses on the documents and records you'll need to present at the U.S. border for a vacation (typically under                             \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   the Visa Waiver Program / ESTA, or a B-2 visitor visa). Here's what to prepare:\u001b[0m                                                                      \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[32m\u001b[1m## 1. Electronic I-94 Arrival Record\u001b[22m\u001b[39m                                                                                                                 \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mThe **I-94** is the electronic arrival/departure record created automatically by U.S. Customs and Border Protection (CBP) when you enter the       \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   U.S. by air or sea. You generally do **not** fill it out in advance \u2014 it's generated upon admission by a CBP officer.\u001b[0m                                \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mAfter arrival, you can view/print your I-94 at the official CBP site: **https://i94.cbp.dhs.gov** (search needed for confirmation of current       \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   URL/process if you want a live link). Travelers entering by land previously used a paper I-94, but most entries are now electronic.\u001b[0m                  \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0m**Action:** Once in the U.S., retrieve and save a copy of your I-94 for your records (useful for proof of lawful status and departure). Keep       \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   your admission stamp/expiration date handy.\u001b[0m                                                                                                          \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[32m\u001b[1m## 2. Return (Round-Trip) Ticket\u001b[22m\u001b[39m                                                                                                                     \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mPrepare a **confirmed round-trip itinerary** showing your departure from the U.S. before your authorized stay ends (typically 90 days under        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   ESTA, 6 months under B-2).\u001b[0m                                                                                                                           \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mKeep a digital and printed copy of t"]
[110.73575899999997, "o", "he booking confirmation with dates, flight numbers, and your name matching your passport.\u001b[0m                      \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mThis demonstrates non-immigrant intent (that you plan to leave).\u001b[0m                                                                                   \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[32m\u001b[1m## 3. Accommodation Details\u001b[22m\u001b[39m                                                                                                                          \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mPrepare a list of where you'll stay: hotel reservations, host confirmations, or an invitation letter from a friend/family host with their          \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   address and contact info.\u001b[0m                                                                                                                            \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mKeep printed or offline-accessible copies. A CBP officer may ask for your U.S. address(es) on arrival.\u001b[0m                                             \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[32m\u001b[1m## 4. Proof of Funds\u001b[22m\u001b[39m                                                                                                                                 \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mPrepare evidence you can financially support your trip: recent bank statements, credit card statements, pay stubs, or a sponsor letter if          \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   someone is funding you.\u001b[0m                                                                                                                              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mCarrying a reasonable amount of accessible funds (or proof of cards) helps show you won't need to work illegally.\u001b[0m                                  \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[32m\u001b[1m## 5. Supporting Identity Documents (good to have ready)\u001b[22m\u001b[39m                                                                                             \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mValid passport (valid at least 6 months beyond your stay).\u001b[0m                                                                                         \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mESTA approval confirmation (if visa-waiver national) or B-2 visa in passport.\u001b[0m                                                                      \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mTravel itinerary and any tour bookings.\u001b[0m                                                                                                            \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0m\u001b[1mNote:\u001b[22m The specific requirements (ESTA vs. visa, I-94 format) depend on your nationality. If you'd like, I can web-search                             \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m"]
[110.73581799999997, "o", "\u2502\u001b[39m   the exact current CBP/ESTA procedures for your country of citizenship \u2014 just let me know your nationality.\u001b[0m                                           \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n\u001b[95m  \u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256f\u001b[39m\r\n\r\n"]
[110.93581799999997, "o", "\u001b[31m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\n\r\n\u001b[48;5;214m\u001b[97m\u001b[1m STEP 10/10 \u001b[22m\u001b[39m\u001b[49m \u001b[38;5;214m\u001b[1mFinal checks and packing\u001b[22m\u001b[39m\r\n\r\n\u001b[38;5;214m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\n"]
