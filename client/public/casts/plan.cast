[69.33323899999995, "o", "\u001b[1G\u001b[J\u001b[32m\u25c7\u001b[39m  \r\n\u001b[?25h\r\n\u001b[32m\u2714\u001b[39m \u001b[92m\u001b[1mBook flights\u001b[22m\u001b[39m\r\n\r\n"]
[69.34858499999997, "o", "\u001b[95m  \u256d \u001b[95m\u2b21 Orbis AI\u001b[39m\u001b[95m \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256e\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[35m\u001b[4m\u001b[1m# Step: Book Flights\u001b[22m\u001b[24m\u001b[39m                                                                                                                                 \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0mFor this step, the actionable plan is to \u001b[1mbook international round-trip flights 2\u20134 months ahead to a major US hub\u001b[22m (JFK,                              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   LAX, SFO, MIA, ORD, or ATL).\u001b[0m                                                                                                                         \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[32m\u001b[1m## What to do\u001b[22m\u001b[39m                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   1. \u001b[0m**Pick your departure city and destination hub** based on where you want to vacation in the US (e.g., JFK/ORD/ATL for the East/Midwest, LAX/SFO   \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   for the West Coast, MIA for Florida).\u001b[0m                                                                                                                \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   2. \u001b[0m**Book 2\u20134 months in advance** of your travel dates \u2014 this window typically offers the best balance of availability and price for international   \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   round-trips.\u001b[0m                                                                                                                                         \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   3. \u001b[0m**Search across major carriers and aggregators** (Google Flights, Skyscanner, Kayak, or the airlines directly) for round-trip fares into your     \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   chosen hub.\u001b[0m                                                                                                                                          \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   4. \u001b[0m**Lock in the booking** once you find a fare that fits your budget and schedule, confirming baggage and change policies.\u001b[0m                          \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[32m\u001b[1m## Notes\u001b[22m\u001b[39m                                                                                                                                             \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mI don't have live flight prices or availability in this session (no web search has been run yet for this step), so I can't recommend a specific    \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   flight or fare.\u001b[0m      "]
[69.34865899999996, "o", "                                                                                                                                \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mIf you tell me your **home city, target US region, and travel month**, I can run a web search to pull current route options and example fares      \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   from a live source.\u001b[0m                                                                                                                                  \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0mThis step is intentionally scoped to flights only \u2014 accommodation, itinerary, and other logistics are handled in                                     \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   separate steps.\u001b[0m                                                                                                                                      \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n\u001b[95m  \u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256f\u001b[39m\r\n\r\n"]
