[25.127847999999968, "o", "\u001b[1G\u001b[J\u001b[32m\u25c7\u001b[39m  \u001b[32m\u2713 Plan ready.\u001b[39m\r\n"]
[25.12831999999997, "o", "\u001b[?25h"]
[25.130414999999967, "o", "\u001b[1m\u001b[22m\r\n\u001b[1m\ud83d\udccb Generated Plan\u001b[22m\r\n\u001b[1m\u001b[22m\r\n"]
[25.130702999999965, "o", "  \u001b[36mStep  1\u001b[39m. \u001b[1mCheck VWP eligibility\u001b[22m \r\n  \u001b[36mStep  2\u001b[39m. \u001b[1mObtain ESTA or visa\u001b[22m \r\n  \u001b[36mStep  3\u001b[39m. \u001b[1mVerify passport validity\u001b[22m \r\n  \u001b[36mStep  4\u001b[39m. \u001b[1mPlan timing and destinations\u001b[22m \r\n  \u001b[36mStep  5\u001b[39m. \u001b[1mCreate itinerary\u001b[22m \r\n  \u001b[36mStep  6\u001b[39m. \u001b[1mBook flights\u001b[22m \r\n  \u001b[36mStep  7\u001b[39m. \u001b[1mArrange lodging and transport\u001b[22m \r\n  \u001b[36mStep  8\u001b[39m. \u001b[1mComplete practical preparations\u001b[22m \r\n"]
[25.130828999999974, "o", "  \u001b[36mStep  9\u001b[39m. \u001b[1mPrepare border documents\u001b[22m \r\n  \u001b[36mStep 10\u001b[39m. \u001b[1mFinal checks and packing\u001b[22m \r\n\r\n"]
[25.133322999999972, "o", "\u001b[?25l\u001b[90m\u2502\u001b[39m\r\n\u001b[36m\u25c6\u001b[39m  Select steps to execute (space toggles, enter confirms)\r\n\u001b[36m\u2502\u001b[39m  \u001b[32m\u25fc\u001b[39m Check VWP eligibility\r\n\u001b[36m\u2502\u001b[39m  \u001b[32m\u25fc\u001b[39m \u001b[2mObtain ESTA or visa\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[32m\u25fc\u001b[39m \u001b[2mVerify passport validity\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[32m\u25fc\u001b[39m \u001b[2mPlan timing and destinations\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[32m\u25fc\u001b[39m \u001b[2mCreate itinerary\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[32m\u25fc\u001b[39m \u001b[2mBook flights\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[32m\u25fc\u001b[39m \u001b[2mArrange lodging and transport\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[32m\u25fc\u001b[39m \u001b[2mComplete practical preparations\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[32m\u25fc\u001b[39m \u001b[2mPrepare border documents\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[32m\u25fc\u001b[39m \u001b[2mFinal checks and packing\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[2m\u2191/\u2193\u001b[22m to navigate \u2022 \u001b[2mSpace:\u001b[22m select \u2022 \u001b[2mEnter:\u001b[22m confirm\r\n\u001b[36m\u2514\u001b[39m\r\n"]
[25.33332299999997, "o", "\u001b[999D\u001b[14A\u001b[1B\u001b[J\u001b[32m\u25c7\u001b[39m  Select steps to execute (space toggles, enter confirms)\r\n\u001b[90m\u2502\u001b[39m  \u001b[2mCheck VWP eligibility\u001b[22m\u001b[2m, \u001b[22m\u001b[2mObtain ESTA or visa\u001b[22m\u001b[2m, \u001b[22m\u001b[2mVerify passport validity\u001b[22m\u001b[2m, \u001b[22m\u001b[2mPlan timing and destinations\u001b[22m\u001b[2m, \u001b[22m\u001b[2mCreate itinerary\u001b[22m\u001b[2m, \u001b[22m\u001b[2mBook flights\u001b[22m\u001b[2m, \u001b[22m\u001b[2mArrange \u001b[22m\r\n\u001b[90m\u2502\u001b[39m  \u001b[2mlodging and transport\u001b[22m\u001b[2m, \u001b[22m\u001b[2mComplete practical preparations\u001b[22m\u001b[2m, \u001b[22m\u001b[2mPrepare border documents\u001b[22m\u001b[2m, \u001b[22m\u001b[2mFinal checks and packing\u001b[22m\r\n"]
[25.33352199999998, "o", "\u001b[?25h"]
[25.334946999999993, "o", "\u001b[?25l\u001b[90m\u2502\u001b[39m\r\n\u001b[36m\u25c6\u001b[39m  \u001b[93mExecute \u001b[96m\u001b[1m10\u001b[22m\u001b[39m\u001b[93m step(s)?\u001b[39m\r\n\u001b[36m\u2502\u001b[39m  \u001b[32m\u25cf\u001b[39m Yes \u001b[2m/\u001b[22m \u001b[2m\u25cb\u001b[22m \u001b[2mNo\u001b[22m\r\n\u001b[36m\u2514\u001b[39m\r\n"]
[25.534946999999992, "o", "\u001b[999D\u001b[4A\u001b[1B\u001b[J\u001b[32m\u25c7\u001b[39m  \u001b[93mExecute \u001b[96m\u001b[1m10\u001b[22m\u001b[39m\u001b[93m step(s)?\u001b[39m\r\n\u001b[90m\u2502\u001b[39m  \u001b[2mYes\u001b[22m\r\n\u001b[?25h"]
[25.73494699999999, "o", "\r\n\u001b[48;5;214m\u001b[97m\u001b[1m STEP 1/10 \u001b[22m\u001b[39m\u001b[49m \u001b[38;5;214m\u001b[1mCheck VWP eligibility\u001b[22m\u001b[39m\r\n\r\n\u001b[38;5;214m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\n"]
