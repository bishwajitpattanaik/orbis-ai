[121.27419499999995, "o", "\u001b[95m  \u256d \u001b[95m\u2b21 Orbis AI\u001b[39m\u001b[95m \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256e\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[35m\u001b[4m\u001b[1m# Final Checks & Packing (Before Departure)\u001b[22m\u001b[24m\u001b[39m                                                                                                          \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[32m\u001b[1m## 1. Documents \u2014 verify and organize\u001b[22m\u001b[39m                                                                                                                \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0m**Passport**: Confirm it's valid for at least 6 months beyond your trip end date, with blank pages.\u001b[0m                                                \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0m**ESTA / Visa**: If you're from a Visa Waiver Program country, confirm your ESTA is approved (print or save the confirmation). If not, confirm     \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   your visa is stamped/issued.\u001b[0m                                                                                                                         \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0m**Flights**: Re-check the airline app/email for any schedule changes; save boarding passes (offline + screenshot). Note your confirmation/PNR      \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   code.\u001b[0m                                                                                                                                                \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0m**Lodging**: Re-confirm hotel/Airbnb/reservation; save address, check-in time, and confirmation number. Note the property's cancellation policy.\u001b[0m   \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0m**Extras**: Travel insurance certificate, rental car reservation (if any), and a copy of your itinerary.\u001b[0m                                           \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0m\u001b[1mTip:\u001b[22m Keep physical + digital copies of every document (cloud/email + offline folder).\u001b[0m                                                                \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[32m\u001b[1m## 2. Money & connectivity\u001b[22m\u001b[39m                                                                                                                           \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mNotify your bank of travel; carry a card with no foreign fees + some USD cash.\u001b[0m                                                                     \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mCheck if your phone plan covers the US or get an eSIM/international add-on.\u001b[0m                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m            "]
[121.27445899999996, "o", "                                                                                                                                            \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[32m\u001b[1m## 3. Packing checklist\u001b[22m\u001b[39m                                                                                                                              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0m**Essentials**: documents folder, phone + charger, power bank, US power adapter (Type A/B, 110V).\u001b[0m                                                  \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0m**Clothing**: weather-appropriate layers, comfortable shoes, one outfit per day + spares.\u001b[0m                                                          \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0m**Toiletries**: travel-size liquids (\u22643.4 oz / 100 ml for carry-on), medications in original packaging.\u001b[0m                                            \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0m**Health**: any prescriptions, basic first-aid, sunglasses.\u001b[0m                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0m**Misc**: reusable water bottle, headphones, books/entertainment, snacks for the flight.\u001b[0m                                                           \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[32m\u001b[1m## 4. Pre-departure house tasks\u001b[22m\u001b[39m                                                                                                                      \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mPause mail/ deliveries, set lights on timers, lock up, unplug non-essentials.\u001b[0m                                                                      \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mCheck weather at destination and pack accordingly.\u001b[0m                                                                                                 \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mWeigh luggage to avoid baggage fees; confirm carry-on rules.\u001b[0m                                                                                       \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[32m\u001b[1m## 5. At the airport\u001b[22m\u001b[39m                                                                                                                                 \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mArrive 3 hours early for international flights.\u001b[0m                                                                                                    \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mHave passport + ESTA/visa ready; keep documents accessible (not buried in checked bag).\u001b[0m                                                            \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mDouble-check you have your phone, wallet, and documents before leaving security.\u001b[0m                                                                   \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0mWant me to tailor this to your specific destination, travel dates, or airline?\u001b[0m                                                 "]
[121.27467599999999, "o", "                      \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n\u001b[95m  \u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256f\u001b[39m\r\n\r\n"]
