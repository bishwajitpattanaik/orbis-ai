[30.36312199999999, "o", "\u001b[1G\u001b[J\u001b[32m\u25c7\u001b[39m  \r\n\u001b[?25h"]
[30.363297000000003, "o", "\r\n\u001b[32m\u2714\u001b[39m \u001b[92m\u001b[1mCheck VWP eligibility\u001b[22m\u001b[39m\r\n\r\n"]
[30.375077999999988, "o", "\u001b[95m  \u256d \u001b[95m\u2b21 Orbis AI\u001b[39m\u001b[95m \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256e\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0mTo check your Visa Waiver Program (VWP) eligibility, I need to know your country of citizenship.\u001b[0m                           \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0mThe VWP lets citizens of ~40 participating countries travel to the U.S. for tourism/business for up to 90 days without a   \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   visa, but they must obtain an \u001b[1mESTA\u001b[22m (Electronic System for Travel Authorization) approval before boarding.\u001b[0m                  \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0m\u001b[1mWhat I need from you:\u001b[22m\u001b[0m                                                                                                      \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m       * \u001b[0mYour citizenship / passport country\u001b[0m                                                                                  \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0m\u001b[1mOnce you tell me, I\u2019ll:\u001b[22m\u001b[0m                                                                                                    \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m       1. \u001b[0mCheck your country against the official VWP country list.\u001b[0m                                                           \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m       2. \u001b[0mTell you whether you qualify for ESTA (no visa needed) or must apply for a tourist visa (B-1/B-2).\u001b[0m                  \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0mPlease share your citizenship and I\u2019ll confirm the eligibility and the ESTA vs. B-1/B-2 requirement for your case.\u001b[0m         \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                              \u001b[95m\u2502\u001b[39m\r\n\u001b[95m  \u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256f\u001b[39m\r\n\r\n"]
[30.57507799999999, "o", "\u001b[31m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\n"]
[30.575592999999998, "o", "\r\n\u001b[48;5;214m\u001b[97m\u001b[1m STEP 2/10 \u001b[22m\u001b[39m\u001b[49m \u001b[38;5;214m\u001b[1mObtain ESTA or visa\u001b[22m\u001b[39m\r\n\r\n\u001b[38;5;214m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\n"]
