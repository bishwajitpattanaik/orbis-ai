[96.93852699999995, "o", "\u001b[1G\u001b[J\u001b[32m\u25c7\u001b[39m  \r\n\u001b[?25h"]
[96.93898799999995, "o", "\r\n\u001b[32m\u2714\u001b[39m \u001b[92m\u001b[1mComplete practical preparations\u001b[22m\u001b[39m\r\n\r\n"]
[96.95955999999997, "o", "\u001b[95m  \u256d \u001b[95m\u2b21 Orbis AI\u001b[39m\u001b[95m \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256e\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[35m\u001b[4m\u001b[1m# Practical Preparations for Your US Vacation\u001b[22m\u001b[24m\u001b[39m                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0mHere's a focused checklist for the logistics you should handle before you fly:\u001b[0m                                                                       \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[32m\u001b[1m## 1. Travel Insurance\u001b[22m\u001b[39m                                                                                                                               \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0m**What to cover:** trip cancellation/interruption, medical emergencies (US healthcare is expensive), baggage loss, and travel delays.\u001b[0m              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0m**Where to look:** Compare providers like Allianz, World Nomads, or your credit card's built-in travel protection (some cards include insurance    \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   if you book with them).\u001b[0m                                                                                                                              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0m**Tip:** Buy it soon after booking flights \u2014 some cancellation benefits only apply if purchased within a window (often 14\u201321 days) of your         \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   initial trip deposit.\u001b[0m                                                                                                                                \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[32m\u001b[1m## 2. Notify Your Bank / Credit Card Companies\u001b[22m\u001b[39m                                                                                                       \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mSet a **travel notice** on debit and credit cards so transactions aren't flagged as fraud.\u001b[0m                                                         \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mMost banks let you do this in their mobile app (\"travel alert\" / \"manage travel\") \u2014 no phone call needed.\u001b[0m                                          \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mCarry **2 cards from different networks** (e.g., Visa + Mastercard) as backup.\u001b[0m                                                                     \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mConfirm your card has **no foreign transaction fees**; if not, consider a travel card.\u001b[0m                                                             \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                 "]
[96.95979699999997, "o", "                                                                                                                                       \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[32m\u001b[1m## 3. Phone Plan (International or US eSIM)\u001b[22m\u001b[39m                                                                                                          \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0m**Option A \u2013 International roaming:** Check your carrier's daily travel pass (e.g., $10\u2013$12/day with some carriers) \u2014 convenient but can add up.\u001b[0m   \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0m**Option B \u2013 US eSIM (usually cheaper):** Providers like Airalo, Holafly, or Nomad offer data eSIMs for the US. Install before departure and       \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   activate on arrival.\u001b[0m                                                                                                                                 \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0m**Check phone compatibility:** Your phone must be unlocked and eSIM-capable.\u001b[0m                                                                       \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mConsider a plan with **hotspot tethering** if you'll also use a laptop/tablet.\u001b[0m                                                                     \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[32m\u001b[1m## 4. Driver's License / International Driving Permit (IDP)\u001b[22m\u001b[39m                                                                                          \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0m**If renting a car:** Your home country's driver's license is often accepted, but many US rental agencies and some states require an **IDP**       \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   alongside it \u2014 especially if your license isn't in English.\u001b[0m                                                                                          \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0m**Get the IDP before you leave** from your home country's automobile association (e.g., AAA in the US issues them; abroad, your local authorized   \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   body).\u001b[0m                                                                                                                                               \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mBring the **physical license + IDP** (digital copies aren't accepted).\u001b[0m                                                                             \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   * \u001b[0mCheck the specific **state's rules** for where you'll be driving, since requirements vary by state.\u001b[0m                                                \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0m-----------------------------------------------------------------------------------------------------------------------\u001b[0m                              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0m\u001b[1mQuick action order:\u001b[22m Get the IDP early (takes processing time) \u2192 compare insurance \u2192 set bank travel alerts (~1 week                                  \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   before) \u2192 install eSIM a few days before departure.\u001b[0m                                                                                             "]
[96.95985599999996, "o", "     \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0mWant me to dig into specific eSIM pricing or IDP issuing bodies for your country? Let me know your home country and I                                \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   can search for verified details.\u001b[0m                                                                                                                     \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                        \u001b[95m\u2502\u001b[39m\r\n\u001b[95m  \u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256f\u001b[39m\r\n\r\n"]
[97.15985599999996, "o", "\u001b[31m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\n\r\n\u001b[48;5;214m\u001b[97m\u001b[1m STEP 9/10 \u001b[22m\u001b[39m\u001b[49m \u001b[38;5;214m\u001b[1mPrepare border documents\u001b[22m\u001b[39m\r\n\r\n\u001b[38;5;214m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\n"]
