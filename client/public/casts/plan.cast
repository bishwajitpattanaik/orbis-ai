[43.921878999999976, "o", "\u001b[1G\u001b[J\u001b[32m\u25c7\u001b[39m  \r\n\u001b[?25h\r\n\u001b[32m\u2714\u001b[39m \u001b[92m\u001b[1mVerify passport validity\u001b[22m\u001b[39m\r\n\r\n"]
[43.931608, "o", "\u001b[95m  \u256d \u001b[95m\u2b21 Orbis AI\u001b[39m\u001b[95m \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256e\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                 \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[32m\u001b[1m## Step: Verify Passport Validity\u001b[22m\u001b[39m                                                                                                             \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                 \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0mTo clear this prerequisite for a US vacation, check two things on your passport:\u001b[0m                                                              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                 \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m       1. \u001b[0m\u001b[0m\u001b[0m**Validity window** \u2014 Your passport must be valid for **at least 6 months beyond your planned departure date from the\u001b[0m                  \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m          \u001b[0mUS**. For example, if you plan to leave the US on December 1, 2025, your passport should not expire before June 1, 2026.\u001b[0m\u001b[0m\u001b[0m               \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m          \u001b[0m\u001b[0m                                                                                                                                       \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m          \u001b[0m                                                                                                                                       \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m           * \u001b[0m\u001b[0mIf it expires sooner, renew it *before* booking non-refundable travel.\u001b[0m\u001b[0m\u001b[0m                                                              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m       2. \u001b[0m\u001b[0m\u001b[0m**e-Passport (chip-enabled)** \u2014 The US uses biometric entry. Confirm your passport has the **electronic chip symbol** on\u001b[0m               \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m          \u001b[0mthe cover (a small rectangle with a circle and two lines, like a camera/aperture icon). Most passports issued after\u001b[0m                    \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m          \u001b[0m~2007 include this, but verify on your physical document.\u001b[0m\u001b[0m\u001b[0m                                                                              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m          \u001b[0m\u001b[0m                                                                                                                                       \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m          \u001b[0m                                                                                                                                       \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m           * \u001b[0m\u001b[0mIf yours is an older non-e-passport, you'll need to renew to one with an embedded chip.\u001b[0m\u001b[0m\u001b[0m                                             \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                 \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0m\u001b[1mAction items:\u001b[22m\u001b[0m                                                                                                                                 \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                 \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m       * \u001b[0mLocate your current passport and read the expiration date.\u001b[0m                                                "]
[43.93176899999999, "o", "                              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m       * \u001b[0mConfirm the e-passport icon is present on the front cover.\u001b[0m                                                                              \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m       * \u001b[0mIf either check fails, start the renewal process with your country's passport authority before proceeding to the next planning steps.\u001b[0m   \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                 \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   \u001b[0mI can't verify your specific passport details \u2014 that requires your physical document. If you'd like, I can search for                         \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m   your country's passport renewal authority or current processing times.\u001b[0m                                                                        \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                 \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                 \u001b[95m\u2502\u001b[39m\r\n  \u001b[95m\u2502\u001b[39m                                                                                                                                                 \u001b[95m\u2502\u001b[39m\r\n\u001b[95m  \u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256f\u001b[39m\r\n\r\n"]
[44.131768999999984, "o", "\u001b[31m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\n\r\n\u001b[48;5;214m\u001b[97m\u001b[1m STEP 4/10 \u001b[22m\u001b[39m\u001b[49m \u001b[38;5;214m\u001b[1mPlan timing and destinations\u001b[22m\u001b[39m\r\n\r\n\u001b[38;5;214m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\n"]
