[11.266717, "o", "\r\n\u001b[93m\u256d\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 \u001b[93m\u001b[1m Orbis \u001b[22m\u001b[39m\u001b[93m \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256e\u001b[39m\r\n\u001b[93m\u2502\u001b[39m                                        \u001b[93m\u2502\u001b[39m\r\n\u001b[93m\u2502\u001b[39m   \u001b[93m\u001b[1mWelcome back, Bishwajit Pattanaik!\u001b[22m\u001b[39m   \u001b[93m\u2502\u001b[39m\r\n\u001b[93m\u2502\u001b[39m                                        \u001b[93m\u2502\u001b[39m\r\n\u001b[93m\u2502\u001b[39m   \u001b[92m\u001b[1mYour workspace is live and ready.\u001b[22m\u001b[39m    \u001b[93m\u2502\u001b[39m\r\n\u001b[93m\u2502\u001b[39m   \u001b[90mWhat would you like to do today?\u001b[39m     \u001b[93m\u2502\u001b[39m\r\n\u001b[93m\u2502\u001b[39m                                        \u001b[93m\u2502\u001b[39m\r\n\u001b[93m\u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256f\u001b[39m\r\n\r\n"]
[11.272777, "o", "\u001b[?25l\u001b[90m\u2502\u001b[39m\r\n\u001b[36m\u25c6\u001b[39m  \u001b[93m\u001b[1mChoose your path:\u001b[22m\u001b[39m\r\n\u001b[36m\u2502\u001b[39m  \u001b[32m\u25cf\u001b[39m \u001b[96m\u001b[1mCLI Mode\u001b[22m\u001b[39m \u001b[2m(\u001b[90mConnect with Orbis via your terminal\u001b[39m)\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[2m\u25cb\u001b[22m \u001b[2m\u001b[92m\u001b[1mTelegram Mode\u001b[22m\u001b[39m\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[2m\u25cb\u001b[22m \u001b[2m\u001b[37m\u001b[1mExit\u001b[22m\u001b[39m\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[2m\u2191/\u2193\u001b[22m to navigate \u2022 \u001b[2mEnter:\u001b[22m confirm\r\n\u001b[36m\u2514\u001b[39m\r\n"]
[12.85431, "o", "\u001b[999D\u001b[7A\u001b[1B\u001b[J\u001b[32m\u25c7\u001b[39m  \u001b[93m\u001b[1mChoose your path:\u001b[22m\u001b[39m\r\n\u001b[90m\u2502\u001b[39m  \u001b[2m\u001b[96m\u001b[1mCLI Mode\u001b[22m\u001b[39m\u001b[22m"]
[12.854413, "o", "\r\n"]
[12.854755, "o", "\u001b[?25h"]
[12.867346, "o", "\u001b[?25l\u001b[90m\u2502\u001b[39m\r\n\u001b[36m\u25c6\u001b[39m  Choose CLI sub-mode\r\n\u001b[36m\u2502\u001b[39m  \u001b[32m\u25cf\u001b[39m Ask Mode\r\n\u001b[36m\u2502\u001b[39m  \u001b[2m\u25cb\u001b[22m \u001b[2mAgent Mode\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[2m\u25cb\u001b[22m \u001b[2mPlan Mode\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[2m\u25cb\u001b[22m \u001b[2m\u2190 Back to main menu\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[2m\u2191/\u2193\u001b[22m to navigate \u2022 \u001b[2mEnter:\u001b[22m confirm\r\n\u001b[36m\u2514\u001b[39m\r\n"]
