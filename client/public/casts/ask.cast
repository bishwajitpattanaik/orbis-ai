[14.055532, "o", "\u001b[92m  \u2554\u2550\u2550\u2550\u2550 \u001b[33m\u2b21 Orbis CLI\u001b[39m\u001b[92m \u2550\u2550\u2550\u2550\u2550\u2557\u001b[39m\r\n  \u001b[92m\u2551\u001b[39m                      \u001b[92m\u2551\u001b[39m\r\n  \u001b[92m\u2551\u001b[39m   \u001b[93m\u001b[1m  \u2753  Ask Mode  \u001b[22m\u001b[39m   \u001b[92m\u2551\u001b[39m\r\n  \u001b[92m\u2551\u001b[39m                      \u001b[92m\u2551\u001b[39m\r\n\u001b[92m  \u255a\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u255d\u001b[39m\r\n"]
[15.700353, "o", "\u001b[?25l\u001b[90m\u2502\u001b[39m\r\n\u001b[36m\u25c6\u001b[39m  \u001b[93mContinue a previous session or start new?\u001b[39m\r\n\u001b[36m\u2502\u001b[39m  \u001b[32m\u25cf\u001b[39m \u001b[92m\uff0b  New Session\u001b[39m\r\n\u001b[36m\u2502\u001b[39m  \u001b[2m\u25cb\u001b[22m \u001b[2m\u001b[96mTell me about Google's Deepmind\u001b[39m\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[2m\u25cb\u001b[22m \u001b[2m\u001b[96mNew ask conversation\u001b[39m\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[2m\u25cb\u001b[22m \u001b[2m\u001b[96mCreate a leetcode problem finder web app for me\u001b[39m\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[2m\u25cb\u001b[22m \u001b[2m\u001b[91m\ud83d\uddd1  Manage / delete sessions\u001b[39m\u001b[22m\r\n\u001b[36m\u2502\u001b[39m  \u001b[2m\u2191/\u2193\u001b[22m to navigate \u2022 \u001b[2mEnter:\u001b[22m confirm\r\n\u001b[36m\u2514\u001b[39m\r\n"]
[16.94265, "o", "\u001b[999D\u001b[9A\u001b[1B\u001b[J\u001b[32m\u25c7\u001b[39m  \u001b[93mContinue a previous session or start new?\u001b[39m\r\n\u001b[90m\u2502\u001b[39m  \u001b[2m\u001b[92m\uff0b  New Session\u001b[39m\u001b[22m\r\n\u001b[?25h"]
[18.114943, "o", "\r\n\u001b[33m\u256d\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 Ask Session \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256e\u001b[39m\r\n\u001b[33m\u2502\u001b[39m                                        \u001b[33m\u2502\u001b[39m\r\n\u001b[33m\u2502\u001b[39m   \u001b[96mSession\u001b[39m:  \u001b[37m\u001b[1mNew ask conversation\u001b[22m\u001b[39m       \u001b[33m\u2502\u001b[39m\r\n\u001b[33m\u2502\u001b[39m   \u001b[96mID:\u001b[39m      \u001b[37m\u001b[1mcmrnqoijm000fz985h0z77gr3\u001b[22m\u001b[39m   \u001b[33m\u2502\u001b[39m\r\n\u001b[33m\u2502\u001b[39m   \u001b[96mMode:\u001b[39m    \u001b[37m\u001b[1mask\u001b[22m\u001b[39m                         \u001b[33m\u2502\u001b[39m\r\n\u001b[33m\u2502\u001b[39m                                        \u001b[33m\u2502\u001b[39m\r\n\u001b[33m\u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256f\u001b[39m\r\n\r\n"]
[19.143092, "o", "\u001b[33m\u256d\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 Tips \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256e\u001b[39m\r\n\u001b[33m\u2502\u001b[39m                                                    \u001b[33m\u2502\u001b[39m\r\n\u001b[33m\u2502\u001b[39m   \u001b[37m\u001b[1m\u2022 Ask anything about your codebase or the web\u001b[22m\u001b[39m    \u001b[33m\u2502\u001b[39m\r\n\u001b[33m\u2502\u001b[39m   \u001b[37m\u001b[1m\u2022 Orbis will research and respond with context\u001b[22m\u001b[39m   \u001b[33m\u2502\u001b[39m\r\n\u001b[33m\u2502\u001b[39m   \u001b[37m\u001b[1m\u2022 You can save any answer to a .md file\u001b[22m\u001b[39m          \u001b[33m\u2502\u001b[39m\r\n\u001b[33m\u2502\u001b[39m   \u001b[37m\u001b[1m\u2022 Press Ctrl+C to quit anytime\u001b[22m\u001b[39m                   \u001b[33m\u2502\u001b[39m\r\n\u001b[33m\u2502\u001b[39m                                                    \u001b[33m\u2502\u001b[39m\r\n\u001b[33m\u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256f\u001b[39m\r\n\r\n\u001b[33m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\n"]
